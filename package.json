{
    "name": "@duckflixapp/backend",
    "module": "src/server.ts",
    "type": "module",
    "version": "0.10.1",
    "private": true,
    "scripts": {
        "start": "bun src/server.ts",
        "dev": "bun --hot src/server.ts",
        "db:push": "drizzle-kit push",
        "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
        "format:check": "prettier --check .",
        "lint": "eslint ./src --ext .ts",
        "format": "prettier --write .",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/nodemailer": "^7.0.11",
        "@types/qrcode": "^1.5.6",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "better-sqlite3": "^12.9.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.3"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@duckflixapp/shared": "^1.0.2",
        "@elysiajs/cors": "^1.4.2",
        "@elysiajs/openapi": "^1.4.15",
        "argon2": "^0.44.0",
        "axios": "^1.15.2",
        "chokidar": "^5.0.0",
        "deepmerge": "^4.3.1",
        "drizzle-orm": "^0.45.2",
        "elysia": "^1.4.28",
        "elysia-helmet": "^3.1.0",
        "elysia-rate-limit": "^4.6.0",
        "iso-639-1": "^3.1.5",
        "iso-639-3": "^3.0.1",
        "jsonwebtoken": "^9.0.3",
        "nodemailer": "^8.0.7",
        "otplib": "^13.4.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "pino-roll": "^4.0.0",
        "qrcode": "^1.5.4",
        "zod": "^4.4.1"
    }
}
